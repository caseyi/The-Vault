# ── The Vault — configuration ────────────────────────────────────────────────
# Copy this file to `.env` (which is gitignored) and fill in your values:
#
#   cp .env.example .env
#
# Then start (or restart) with:  docker-compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude AI (optional) ──────────────────────────────────────────────────────
# Only needed for the AI features (auto-tagging, image finder, per-model chat).
# Leave blank to run The Vault without any AI features.
CLAUDE_API_KEY=

# Optional: pin a specific Claude model (defaults to claude-haiku-4-5-20251001).
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Web port ──────────────────────────────────────────────────────────────────
# The Vault UI is served here:  http://<your-nas-ip>:<WEB_PORT>
WEB_PORT=8484

# ── Primary library (a folder on THIS machine) ────────────────────────────────
# LIBRARY_HOST_PATH = the real folder on your NAS/host that holds your prints.
# LIBRARY_NAME      = the label it shows up under inside the app.
LIBRARY_HOST_PATH=/volume1/STL Archive
LIBRARY_NAME=STL Archive

# ── A second LOCAL folder (optional) ──────────────────────────────────────────
# Uncomment here AND uncomment the matching line in docker-compose.yml.
# LIBRARY2_HOST_PATH=/volume1/More Prints
# LIBRARY2_NAME=More Prints

# ── A folder on a REMOTE NAS over SMB / CIFS (optional) ───────────────────────
# Use this when your prints live on a *different* NAS reached over the network.
# Fill these in, then uncomment the `smb_library` block in docker-compose.yml
# (both the volume line and the volume definition at the bottom).
#
#   SMB_HOST   = the other NAS hostname or IP (no slashes), e.g. 192.168.1.50
#   SMB_SHARE  = the shared folder name on that NAS, e.g. 3dprints
#   SMB_USER   = a user that can read the share
#   SMB_PASS   = that user's password
#   SMB_NAME   = the label it shows up under inside the app
SMB_HOST=192.168.1.50
SMB_SHARE=3dprints
SMB_USER=
SMB_PASS=
SMB_NAME=remote
